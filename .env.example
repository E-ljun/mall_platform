# ==================== 数据库配置 ====================
# 本地 MySQL（默认）：
#   DB_HOST=localhost
#   DB_PORT=3306
#   DB_USER=root
#   DB_PASSWORD=你的密码
#   DB_SSL=false
#
# TiDB Cloud（云数据库，免费 5GB）：
#   DB_HOST=gateway01.xxxxxx.prod.aws.tidbcloud.com
#   DB_PORT=4000
#   DB_USER=2xxxxxx.root
#   DB_PASSWORD=你设置的密码
#   DB_SSL=true

DB_PASSWORD=mall123456
DB_SSL=false

# ==================== JWT 安全 ====================
JWT_SECRET=your-long-random-jwt-secret-key-at-least-32-chars

# ==================== AI 接口密钥 ====================
# DashScope（阿里云百炼），注册地址: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxx
# DeepSeek（可选，作为 JSON 解析失败的备用模型）
DEEPSEEK_API_KEY=
