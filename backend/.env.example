# 数据库
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mall_content
DB_USER=root
DB_PASSWORD=xyz567

# JWT（生产环境务必更换，至少 32 字符）
JWT_SECRET=your-long-random-jwt-secret-key-at-least-32-chars

# 阿里云通义千问（百炼 DashScope）— 主力 API
# 申请：https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxx

# DeepSeek — 文本备用（可选）
DEEPSEEK_API_KEY=sk-xxxxxxxx

# 文件存储目录
STORAGE_ROOT=./storage

# 跨域（生产环境填你的域名，逗号分隔）
CORS_ORIGINS=http://your-server-ip,http://your-domain.com

SPRING_PROFILES_ACTIVE=prod
